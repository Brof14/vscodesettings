{
  // ---  UI & Visuals (Minimalism & Comfort) ---
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": false,
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "editor.minimap.enabled": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "breadcrumbs.showFiles": false,
  "editor.glyphMargin": false,
  "editor.renderControlCharacters": false,

  // --- ✍️ Editor Core ---
  "editor.fontSize": 15, // Оптимально для 1080p/2K мониторов
  "editor.lineHeight": 24,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
  "editor.fontLigatures": true,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "expand",
  "editor.cursorStyle": "line-thin",
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.detectIndentation": false, // Важно для строгого контроля отступов

  // --- ⚙️ Language Specifics (The Magic) ---

  // GO: Табы, gofmt, авто-импорты
  "[go]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  // PYTHON: 4 пробела, Black formatter
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },

  // JAVASCRIPT/TYPESCRIPT: Prettier, 2 пробела, без точек с запятой
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // HTML: Стандартный форматер или Prettier
  "[html]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "vscode.html-language-features"
  },

  // --- 🛠 Extensions & Tools ---
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.arrowParens": "avoid",
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "git.enableSmartCommit": true,
  "explorer.confirmDelete": false,
  "files.autoSave": "onFocusChange",

  // ---  Clean Up (Hide noise) ---
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/.DS_Store": true
  },

  // --- 🧩 Material Icon Theme Config ---
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.theme": "classic",

  // ---  Performance ---
  "editor.bracketPairColorization.enabled": false, // Меньше нагрузки на GPU
  "github.copilot.editor.enableAutoCompletions": true
}
